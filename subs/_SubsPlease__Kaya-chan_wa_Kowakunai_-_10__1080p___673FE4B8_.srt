<font face="Roboto Medium" size="26"><b><font face="Georgia">{\an8}<font size="12"><font color="#1e1a15">Hatsu</font></font></font></b></font>

307
00:16:57,250 --> 00:17:03,500
<font face="Roboto Medium" size="26"><b><font face="Georgia">{\an8}<font size="12"><font color="#1e1a15">Jyukichi</font></font></font></b></font>

308
00:16:57,250 --> 00:17:03,500
<font face="Roboto Medium" size="26"><b><font face="Georgia">{\an8}<font size="7"><font color="#1e1a15">(Yebisumori
family
ancestor)</font></font></font></b></font>

309
00:16:57,250 --> 00:17:03,500
<font face="Roboto Medium" size="26"><b><font face="Georgia">{\an8}<font size="12"><font color="#1e1a15">Sosuke</font></font></font></b></font>

310
00:16:57,250 --> 00:17:03,500
<font face="Roboto Medium" size="26"><b><font face="Georgia">{\an8}<font size="12"><font color="#1e1a15">Fumi</font></font></font></b></font>

311
00:16:57,250 --> 00:17:03,500
<font face="Roboto Medium" size="26"><b><font face="Georgia">{\an8}<font size="12"><font color="#1e1a15">Michiko</font></font></font></b></font>

312
